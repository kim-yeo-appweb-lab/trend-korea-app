{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"permissions": {
		"allow": [
      "mcp__plugin_context",
      "mcp__plugin_context7",
      "mcp__plugin_serena",
      "mcp__playwright",
      "mcp__sequential-thinking",
      "mcp__context7",
      "mcp__serena",
      "mcp__shrimp-task-manager",
      "mcp__shadcn"
		]
	},
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-check.sh",
						"timeout": 30000
					}
				]
			}
		]
	}
}
