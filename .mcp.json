{
	"mcpServers": {
		"context7": {
			"type": "http",
			"url": "https://mcp.context7.com/mcp"
		},
		"playwright": {
			"type": "stdio",
			"command": "npx",
			"args": ["@playwright/mcp@latest"],
			"env": {}
		},
		"sequential-thinking": {
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
		},
		"serena": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"--from",
				"git+https://github.com/oraios/serena",
				"serena",
				"start-mcp-server",
				"--context=claude-code",
				"--project-from-cwd",
				"--open-web-dashboard=false"
			]
		},
		"shadcn": {
			"command": "npx",
			"args": ["shadcn@latest", "mcp"]
		},
		"shrimp-task-manager": {
			"command": "node",
			"args": ["/Users/changyu/Base/@local-mcp/mcp-shrimp-task-manager/dist/index.js"],
			"env": {
				"DATA_DIR": "/Users/changyu/Base/kim-yeo-appweb-lab/trend-korea-app/shrimp_data",
				"TEMPLATES_USE": "ko",
				"ENABLE_GUI": "true"
			}
		}
	}
}
